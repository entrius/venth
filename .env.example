# Copy this file to `.env` and fill in your own keys.
# `.env` is git-ignored and MUST NOT be committed.

# Synth API (optional for tools that can run in mock mode)
SYNTH_API_KEY=your-synth-api-key-here

# Options GPS – optional real exchange integrations
# When unset, Options GPS uses a built-in mock multi-exchange provider
# for Market Line Shopping. Real adapters can read these values
# and fall back to the mock provider when not present.
AEVO_API_KEY=your-aevo-api-key-here
DERIBIT_CLIENT_ID=your-deribit-client-id-here
DERIBIT_CLIENT_SECRET=your-deribit-client-secret-here

