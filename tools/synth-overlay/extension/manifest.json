{
    "manifest_version": 3,
    "name": "Synth Overlay: Polymarket Edge",
    "version": "1.0",
    "description": "Displays live Synth Data probability edge directly on Polymarket assets.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://*.polymarket.com/*",
        "http://127.0.0.1:8000/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://polymarket.com/event/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}